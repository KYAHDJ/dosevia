<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_large_background"
    android:padding="14dp">

    <!-- Header Card — metallic silver pill-shaped bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/widget_header_background"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_marginBottom="10dp">

        <TextView
            android:id="@+id/widget_calendar_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PILL PACK"
            android:textSize="18sp"
            android:textColor="#1F2937"
            android:fontFamily="sans-serif-black"
            android:gravity="center"
            android:letterSpacing="0.2"/>

        <TextView
            android:id="@+id/widget_calendar_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="28 Day Calendar"
            android:textSize="11sp"
            android:textColor="#6B7280"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:layout_marginTop="2dp"/>

    </LinearLayout>

    <!-- Week Day Headers: S  M  T  W  T  F  S -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="4dp">

        <TextView style="@style/WeekDayHeader" android:text="S"/>
        <TextView style="@style/WeekDayHeader" android:text="M"/>
        <TextView style="@style/WeekDayHeader" android:text="T"/>
        <TextView style="@style/WeekDayHeader" android:text="W"/>
        <TextView style="@style/WeekDayHeader" android:text="T"/>
        <TextView style="@style/WeekDayHeader" android:text="F"/>
        <TextView style="@style/WeekDayHeader" android:text="S"/>

    </LinearLayout>

    <!-- Row 1: pills 1-7 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:layout_marginBottom="4dp">
        <TextView android:id="@+id/pill_1"  style="@style/PillCircle" android:text="1"/>
        <TextView android:id="@+id/pill_2"  style="@style/PillCircle" android:text="2"/>
        <TextView android:id="@+id/pill_3"  style="@style/PillCircle" android:text="3"/>
        <TextView android:id="@+id/pill_4"  style="@style/PillCircle" android:text="4"/>
        <TextView android:id="@+id/pill_5"  style="@style/PillCircle" android:text="5"/>
        <TextView android:id="@+id/pill_6"  style="@style/PillCircle" android:text="6"/>
        <TextView android:id="@+id/pill_7"  style="@style/PillCircle" android:text="7"/>
    </LinearLayout>

    <!-- Row 2: pills 8-14 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:layout_marginBottom="4dp">
        <TextView android:id="@+id/pill_8"  style="@style/PillCircle" android:text="8"/>
        <TextView android:id="@+id/pill_9"  style="@style/PillCircle" android:text="9"/>
        <TextView android:id="@+id/pill_10" style="@style/PillCircle" android:text="10"/>
        <TextView android:id="@+id/pill_11" style="@style/PillCircle" android:text="11"/>
        <TextView android:id="@+id/pill_12" style="@style/PillCircle" android:text="12"/>
        <TextView android:id="@+id/pill_13" style="@style/PillCircle" android:text="13"/>
        <TextView android:id="@+id/pill_14" style="@style/PillCircle" android:text="14"/>
    </LinearLayout>

    <!-- Row 3: pills 15-21 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:layout_marginBottom="4dp">
        <TextView android:id="@+id/pill_15" style="@style/PillCircle" android:text="15"/>
        <TextView android:id="@+id/pill_16" style="@style/PillCircle" android:text="16"/>
        <TextView android:id="@+id/pill_17" style="@style/PillCircle" android:text="17"/>
        <TextView android:id="@+id/pill_18" style="@style/PillCircle" android:text="18"/>
        <TextView android:id="@+id/pill_19" style="@style/PillCircle" android:text="19"/>
        <TextView android:id="@+id/pill_20" style="@style/PillCircle" android:text="20"/>
        <TextView android:id="@+id/pill_21" style="@style/PillCircle" android:text="21"/>
    </LinearLayout>

    <!-- Row 4: pills 22-28 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">
        <TextView android:id="@+id/pill_22" style="@style/PillCircle" android:text="22"/>
        <TextView android:id="@+id/pill_23" style="@style/PillCircle" android:text="23"/>
        <TextView android:id="@+id/pill_24" style="@style/PillCircle" android:text="24"/>
        <TextView android:id="@+id/pill_25" style="@style/PillCircle" android:text="25"/>
        <TextView android:id="@+id/pill_26" style="@style/PillCircle" android:text="26"/>
        <TextView android:id="@+id/pill_27" style="@style/PillCircle" android:text="27"/>
        <TextView android:id="@+id/pill_28" style="@style/PillCircle" android:text="28"/>
    </LinearLayout>

</LinearLayout>
