<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_small_background"
    android:padding="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="18dp"
        android:paddingEnd="14dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <!-- Left: label + count -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- "PILLS TAKEN TODAY" label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PILLS TAKEN TODAY"
                android:textSize="9sp"
                android:textColor="#9CA3AF"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.08"
                android:layout_marginBottom="2dp"/>

            <!-- "1 / 28" row -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="bottom">

                <TextView
                    android:id="@+id/widget_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1"
                    android:textSize="36sp"
                    android:textColor="#111827"
                    android:fontFamily="sans-serif-black"/>

                <TextView
                    android:id="@+id/widget_total"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="/ 28"
                    android:textSize="18sp"
                    android:textColor="#9CA3AF"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginStart="4dp"
                    android:layout_marginBottom="6dp"/>

            </LinearLayout>
        </LinearLayout>

        <!-- Right: pink circle icon -->
        <RelativeLayout
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/widget_icon_background">

            <!-- Checkmark circle — shown by default (matches reference image) -->
            <ImageView
                android:id="@+id/widget_checkmark"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_centerInParent="true"
                android:src="@drawable/ic_check_circle"
                android:tint="#FFFFFF"
                android:visibility="visible"/>

            <!-- Pill icon — only shown when all pills taken -->
            <ImageView
                android:id="@+id/widget_pill_icon"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_centerInParent="true"
                android:src="@drawable/ic_pill"
                android:tint="#FFFFFF"
                android:visibility="gone"/>

        </RelativeLayout>
    </LinearLayout>

</RelativeLayout>
