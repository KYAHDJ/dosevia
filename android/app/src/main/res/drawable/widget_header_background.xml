<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow layer -->
    <item android:top="1dp" android:left="1dp" android:right="1dp">
        <shape android:shape="rectangle">
            <solid android:color="#40000000"/>
            <corners android:radius="14dp"/>
        </shape>
    </item>
    <!-- Main glass/silver gradient -->
    <item android:bottom="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="180"
                android:startColor="#D6D6D6"
                android:centerColor="#ECECEC"
                android:endColor="#B8B8B8"
                android:type="linear"/>
            <corners android:radius="14dp"/>
            <stroke
                android:width="1dp"
                android:color="#9CA3AF"/>
        </shape>
    </item>
    <!-- Top highlight shine (covers top half of the ~60dp header) -->
    <item android:bottom="30dp" android:left="4dp" android:top="2dp" android:right="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#30FFFFFF"/>
            <corners android:radius="12dp"/>
        </shape>
    </item>
</layer-list>
