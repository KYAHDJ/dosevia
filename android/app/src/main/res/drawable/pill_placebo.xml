<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow -->
    <item android:top="1dp">
        <shape android:shape="oval">
            <solid android:color="#20000000"/>
        </shape>
    </item>
    <!-- Main gradient (lighter/different color for placebo) -->
    <item android:bottom="1dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="50%p"
                android:startColor="#FDE68A"
                android:centerColor="#FCD34D"
                android:endColor="#FBBF24"/>
            <stroke
                android:width="2dp"
                android:color="#92400E"/>
        </shape>
    </item>
    <!-- Highlight shine -->
    <item android:bottom="1dp" android:left="6dp" android:top="6dp" android:right="14dp">
        <shape android:shape="oval">
            <solid android:color="#50FFFFFF"/>
        </shape>
    </item>
</layer-list>
